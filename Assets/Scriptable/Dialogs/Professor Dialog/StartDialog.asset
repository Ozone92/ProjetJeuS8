  m_Script: {fileID: 11500000, guid: 47e8c251aa9a4d95ca6b84096cf8588c, type: 3}
  m_Name: StartDialog
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  dialogs:
  - id: begin
    speaker: Professeur
    text: Bienvenue dans ce nouveau TP ! Aujourd'hui nous allons faire notre propre
      soda !
    cameraPosition: {x: 0, y: 3, z: 3}
    cameraRotation: {x: 10, y: 0, z: 0}
    statsToChange: 
    amount: 0
    choices:
    - text: Enthousiate
      idToGo: happy
    - text: Pas motive
      idToGo: unhappy
  - id: happy
    speaker: Professeur
    text: Je vois que le sujet vous plait !
    cameraPosition: {x: 0, y: 3, z: 3}
    cameraRotation: {x: 10, y: 0, z: 0}
    statsToChange: happy
    amount: 1
    choices:
    - text: 
      idToGo: prof1
  - id: unhappy
    speaker: Professeur
    text: (Je pensais que le sujet leur plairait plus...)
    cameraPosition: {x: 0, y: 1.5, z: 6.5}
    cameraRotation: {x: 10, y: 0, z: 0}
    statsToChange: happy
    amount: -1
    choices:
    - text: 
      idToGo: prof1
  - id: prof1
    speaker: Professeur
    text: Tout d'abord, mettez vous en groupe de 3.
    cameraPosition: {x: 0, y: 3, z: 3}
    cameraRotation: {x: 10, y: 0, z: 0}
    statsToChange: 
    amount: 0
    choices: []
